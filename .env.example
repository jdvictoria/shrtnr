# ── Database ──────────────────────────────────────────────────────────────────
# Prisma Postgres: https://console.prisma.io
# Standard Postgres: postgresql://user:password@localhost:5432/shrten
DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# https://console.upstash.com → Create database → REST API
UPSTASH_REDIS_REST_URL="https://YOUR_ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-random-32-char-secret"

# GitHub OAuth (free): https://github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/callback/github
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

